ORACLE_DATABASE=bytedesk
ORACLE_PASSWORD=r8FqfdbWUaN3
ORACLE_APP_USER=bytedesk
ORACLE_APP_USER_PASSWORD=r8FqfdbWUaN3

# =====================================
# Call scenario / 呼叫中心场景
# =====================================
FREESWITCH_DOMAIN=192.168.0.196
FREESWITCH_EXTERNAL_SIP_IP=192.168.0.196
FREESWITCH_EXTERNAL_RTP_IP=192.168.0.196
FREESWITCH_DEFAULT_PASSWORD=123456
FREESWITCH_ESL_PASSWORD=123456

# FreeSWITCH runtime overrides / FreeSWITCH 运行参数覆盖
# 说明：以下变量会覆盖 deploy/freeswitch/conf/vars.xml 中默认值
# 若 starter 运行在宿主机，Docker 内请使用 host.docker.internal 而不是 127.0.0.1
FREESWITCH_CDR_PASSWORD=123456
FREESWITCH_XML_CURL_TOKEN=change_me_in_production
FREESWITCH_XML_CURL_GATEWAY_URL=http://host.docker.internal:9003/freeswitch/api/v1/xmlcurl
FREESWITCH_API_BASE_URL=http://host.docker.internal:9003
FREESWITCH_DB_HOST=bytedesk-db
FREESWITCH_DB_PORT=3306
FREESWITCH_DB_NAME=bytedesk_freeswitch
FREESWITCH_DB_USERNAME=root
FREESWITCH_DB_PASSWORD=r8FqfdbWUaN3
FREESWITCH_STUN_SERVER=stun:bytedesk-coturn:3478
FREESWITCH_RTP_START_PORT=16000
FREESWITCH_RTP_END_PORT=16129

# =====================================
# WebRTC / Janus secrets / 音视频客服敏感配置
# 说明：普通 WebRTC 地址和默认参数保留在 compose 文件中；
# 这里只放需要外置管理的敏感值，例如 Janus Admin Secret。
# =====================================
COTURN_REALM=bytedesk.local
COTURN_USER=bytedesk
COTURN_PASS=bytedesk123
# 
JANUS_ADMIN_SECRET=janusoverlord

# =====================================
# Bytedesk security / 微语安全配置
# 参考获取License Key: https://www.weiyuai.cn/docs/zh-CN/docs/development/license
# =====================================
BYTEDESK_LICENSE_KEY=
BYTEDESK_ADMIN_PASSWORD=admin
BYTEDESK_ADMIN_VALIDATE_CODE=123456
BYTEDESK_MEMBER_PASSWORD=123456
BYTEDESK_JWT_SECRET_KEY=1dfaf8d004207b628a9a6b859c429f49a9a7ead9fd8161c1e60847aeef06dbd2

# =====================================
# AI provider API keys (optional) / AI 提供商密钥（可选）
# =====================================
SPRING_AI_ZHIPUAI_API_KEY=
SPRING_AI_DEEPSEEK_API_KEY=
SPRING_AI_OPENAI_API_KEY=
SPRING_AI_DASHSCOPE_API_KEY=
SPRING_AI_DASHSCOPE_AUDIO_SYNTHESIS_API_KEY=
SPRING_AI_DASHSCOPE_AUDIO_TRANSCRIPTION_API_KEY=
SPRING_AI_SILICONFLOW_API_KEY=
SPRING_AI_GITEE_API_KEY=
SPRING_AI_TENCENT_API_KEY=
SPRING_AI_BAIDU_API_KEY=
SPRING_AI_VOLCENGINE_API_KEY=

# =====================================
# Optional local ASR/TTS service / 可选本地 ASR/TTS 服务
# =====================================
FUNASR_DEVICE=cpu
FUNASR_MODEL=iic/SenseVoiceSmall
FUNASR_VAD_MODEL=fsmn-vad
FUNASR_MAX_URL_FILE_SIZE=52428800
FUNASR_PRELOAD=false
FUNASR_DISABLE_UPDATE=true
FUNASR_TRUST_REMOTE_CODE=false

TTS_PROVIDER=voxcpm

VOXCPM_MODEL=openbmb/VoxCPM2
VOXCPM_SOURCE=modelscope
VOXCPM_MODELSCOPE_MODEL=OpenBMB/VoxCPM2
VOXCPM_DEVICE=cpu
VOXCPM_LOAD_DENOISER=false
VOXCPM_PRELOAD=false

QWEN_TTS_MODEL=Qwen/Qwen3-TTS-12Hz-1.7B-CustomVoice
QWEN_TTS_SOURCE=modelscope
QWEN_TTS_MODELSCOPE_MODEL=Qwen/Qwen3-TTS-12Hz-1.7B-CustomVoice
QWEN_TTS_DEVICE_MAP=cpu
QWEN_TTS_LANGUAGE=Auto
QWEN_TTS_SPEAKER=Vivian
QWEN_TTS_PRELOAD=false

# =====================================
# Optional third-party config / 可选三方配置
# =====================================
BYTEDESK_TRANSLATE_BAIDU_APPID=
BYTEDESK_TRANSLATE_BAIDU_KEY=

# Optional: provide this only when using ENC(...) values with Jasypt
JASYPT_ENCRYPTOR_PASSWORD=
